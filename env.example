# Copy these into Vercel → Project Settings → Environment Variables
# Do NOT commit real values to the repo

ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_ORG_ID=851436427

ZAPIER_HOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_HOOK_ID/

# A random secret string to protect the /api/sync endpoint
# Generate one with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
